rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Pending subscribers: anyone can create (verification flow)
    match /pending_subscribers/{doc} {
      allow create: if request.resource.data.email is string
                    && request.resource.data.topics is list
                    && request.resource.data.topics.size() > 0
                    && request.resource.data.token is string;
    }

    // Subscribers: only Cloud Functions (admin SDK) can write
    match /subscribers/{email} {
      allow read: if false;
    }

    // Suggestions: anyone can suggest a topic
    match /suggestions/{doc} {
      allow create: if request.resource.data.track is string
                    && request.resource.data.topic is string;
    }

    // User progress: authenticated users can only access their own data
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null
                         && request.auth.uid == userId;
    }
  }
}
