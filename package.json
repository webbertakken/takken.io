{
  "name": "takken-io",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "scripts": {
    "docusaurus": "docusaurus",
    "dev": "docusaurus start",
    "build": "docusaurus build && yarn security-check",
    "security-check": "vitest run --config vitest.config.post-build.ts --reporter=verbose",
    "swizzle": "docusaurus swizzle",
    "deploy": "docusaurus deploy",
    "clear": "docusaurus clear",
    "serve": "docusaurus serve",
    "write-translations": "docusaurus write-translations",
    "write-heading-ids": "docusaurus write-heading-ids",
    "test": "vitest",
    "coverage": "vitest --coverage",
    "lint": "yarn lint:js && yarn lint:css",
    "lint:js": "git ls-files -z ':!functions' '*.ts' '*.tsx' '*.js' '*.jsx' '*.mts' '*.mjs' '*.cjs' | xargs -0 oxlint --max-warnings 0",
    "lint:css": "stylelint **/*.{css,scss,sass} --fix",
    "format": "prettier --write .",
    "fix": "yarn format && yarn lint:css && yarn lint --fix",
    "typecheck": "tsgo --skipLibCheck --noEmit",
    "prepare": "husky",
    "image": "ts-node tools/image-generator/index.ts"
  },
  "lint-staged": {
    "*.@(sh|bash|zsh|fish)": [
      "shellcheck",
      "git update-index --chmod=+x"
    ],
    "*.@(ts|tsx|mts)": "bash -c 'tsgo --skipLibCheck --noEmit'",
    "*.@(ts|tsx|mts|js|jsx|mjs|cjs)": [
      "oxlint --max-warnings 0",
      "vitest related --run"
    ],
    "*.@(ts|tsx|mts|js|jsx|mjs|cjs|json|jsonc|json5|md|mdx|yaml|yml)": "prettier --write",
    "*.@(css|scss|sass)": "stylelint --fix",
    "{blog,notes}/**/*.@(md|mdx)": "node tools/validate-frontmatter.mjs"
  },
  "dependencies": {
    "@docusaurus/core": "^3.10.0",
    "@docusaurus/module-type-aliases": "^3.10.0",
    "@docusaurus/plugin-ideal-image": "^3.10.0",
    "@docusaurus/plugin-pwa": "^3.10.0",
    "@docusaurus/preset-classic": "^3.10.0",
    "@docusaurus/theme-mermaid": "^3.10.0",
    "@docusaurus/utils-validation": "^3.10.0",
    "@garmin-fit/sdk": "^21.115.0",
    "@giscus/react": "^3.1.0",
    "@mdx-js/react": "^3.1.1",
    "@react-spring/web": "^10.0.3",
    "@types/dedent": "^0.7.2",
    "@types/react-dom": "^19",
    "canvas": "^3.2.3",
    "clsx": "^2.1.1",
    "docusaurus-gtm-plugin": "^0.0.2",
    "docusaurus-plugin-content-gists": "^4.0.0",
    "docusaurus-plugin-sass": "^0.2.6",
    "fflate": "^0.8.2",
    "firebase": "^12.12.1",
    "js-cookie": "^3.0.5",
    "node-fetch": "2",
    "prism-react-renderer": "^2.4.1",
    "qrcode.react": "^4.2.0",
    "react": "^19",
    "react-dom": "^19",
    "react-hot-toast": "^2.6.0",
    "react-icons": "^5.6.0",
    "react-simple-code-editor": "^0.14.1",
    "react-three-fiber": "^6.0.13",
    "sass": "^1.99.0",
    "sharp": "^0.34.5",
    "three": "^0.184.0",
    "ts-dedent": "^2.2.0"
  },
  "devDependencies": {
    "@docusaurus/module-type-aliases": "^3.10.0",
    "@docusaurus/types": "^3.10.0",
    "@tailwindcss/webpack": "^4.2.4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/react-hooks": "^8.0.1",
    "@types/glob": "^9.0.0",
    "@types/jest": "^30.0.0",
    "@types/js-cookie": "^3.0.6",
    "@types/node": "^25",
    "@types/react": "^19",
    "@typescript/native-preview": "7.0.0-dev.20260425.1",
    "@vitest/coverage-v8": "^4",
    "cross-env": "^10",
    "dotenv": "^17.4.2",
    "glob": "^13.0.6",
    "husky": "^9",
    "jsdom": "^29",
    "lint-staged": "^16",
    "oxlint": "^1.61.0",
    "prettier": "^3.8.3",
    "shellcheck": "^4",
    "stylelint": "^17",
    "stylelint-config-standard": "^40",
    "stylelint-config-tailwindcss": "^1.0.1",
    "stylelint-scss": "^7",
    "tailwindcss": "^4.2.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vitest": "^4",
    "yarn-upgrade-all": "^0.8.1"
  },
  "resolutions": {
    "sharp": "^0.34.4",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "protobufjs": "^7.5.5",
    "lodash": "^4.17.23",
    "lodash-es": "^4.17.23",
    "node-forge": "^1.3.2",
    "picomatch": "^2.3.2",
    "dompurify": "^3.2.7",
    "path-to-regexp@~0.1.12": "^0.1.13",
    "path-to-regexp@^1.7.0": "^1.9.0",
    "on-headers": "^1.1.0",
    "micromatch": "^4.0.8",
    "qs": "^6.14.1",
    "mdast-util-to-hast": "^13.2.1",
    "webpack": "~5.97.1"
  },
  "browserslist": {
    "production": [
      ">0.5%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "volta": {
    "node": "22.13.1",
    "yarn": "4.9.2"
  },
  "packageManager": "yarn@4.9.2"
}
